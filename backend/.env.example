# ============================================================
#  Harshil/OS — Backend environment (TEMPLATE)
#  Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================

# ---- Database (optional) --------------------------------------------------
# MongoDB stores contact submissions. The app runs fine without it — the
# contact form falls back to email + a durable local file.
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=harshil_os

# ---- CORS -----------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# Production example: CORS_ORIGINS=https://harshiljain.online
CORS_ORIGINS=http://localhost:3000

# ---- Admin panel ----------------------------------------------------------
# Password for /admin login, and a long random string used to sign sessions.
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_JWT_SECRET=change-me-to-a-long-random-secret

# ---- AI providers ---------------------------------------------------------
# Configure ONE OR MORE. The assistant auto-detects available providers and
# falls back between them in order (OpenRouter -> OpenAI -> Gemini -> Anthropic).
# Keys must be VALID and FUNDED for live generation; otherwise the assistant
# answers from grounded retrieval.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# (Alternatives the code also accepts)
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# Optional overrides (else auto-detect + per-provider defaults are used):
# ASSISTANT_PROVIDER=openrouter        # pin a provider (still falls back)
# ASSISTANT_MODEL=anthropic/claude-sonnet-4

# ---- Email (contact form via Resend) --------------------------------------
# All three required to actually send. RESEND_FROM must be a verified sender;
# `onboarding@resend.dev` works for testing (delivers to the account owner).
RESEND_API_KEY=
RESEND_TO=you@example.com
RESEND_FROM=onboarding@resend.dev

# ---- GitHub ---------------------------------------------------------------
# Public username whose repositories are shown on the Developer page.
PORTFOLIO_GITHUB_USER=your-github-username

# ---- Misc (optional) ------------------------------------------------------
# Public site URL — used as the OpenRouter referer header / SEO.
# SITE_PUBLIC_URL=https://harshiljain.online
