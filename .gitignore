# ============================================================
#  Harshil/OS — .gitignore
# ============================================================

# ---- Secrets & environment (NEVER commit) ----
.env
.env.*
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.key
*.pem
credentials.json
*credentials.json*
*token.json*
.credentials
# ...but DO keep the example templates:
!.env.example
!backend/.env.example
!frontend/.env.example

# ---- Node / frontend ----
node_modules/
/.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/coverage

# ---- Build output ----
/build
build/
dist/
dist
/out
/.next/
next-env.d.ts
*.tsbuildinfo

# ---- Python / backend ----
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
*.egg-info/

# ---- Runtime data (environment-specific, may contain PII) ----
dump.rdb
*.sqlite3
backend/contact_submissions.jsonl

# ---- Editors / IDE ----
.idea/
.vscode/
*.swp

# ---- OS files ----
.DS_Store
Thumbs.db

# ---- Deployment ----
.vercel

# ---- Archives / large binaries ----
**/*.zip
**/*.tar
**/*.tar.gz
**/*.tgz
*.pack
*.deb
*.dylib
.cache/

# ---- Internal tooling (not part of the public project) ----
.claude/
.emergent/
.gitconfig
memory/
test_reports/
test_result.md
design_guidelines.json

# NOTE: backend/uploads/ (resume PDFs, media) IS committed so the site
# deploys with its content. Remove it here + `git rm -r --cached` if you
# prefer to manage media only through the admin panel.
